{
  "name": "@jjlabsio/create-jjlabs-app",
  "version": "0.2.0",
  "description": "CLI to scaffold a new JJLabs app from the starter template",
  "type": "module",
  "bin": {
    "create-jjlabs-app": "dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:pack-env": "node scripts/check-pack-env.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "prepublishOnly": "pnpm test:pack-env",
    "publish:npm": "pnpm build && find template \\( -name node_modules -o -name .next -o -name .turbo -o -name .vercel -o -name build -o -name coverage -o -name dist -o -name out \\) -type d -prune -exec rm -rf {} + && pnpm test:pack-env && npm publish --provenance --access public"
  },
  "dependencies": {
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "picomatch": "^4.0.4",
      "postcss": "^8.5.10"
    }
  }
}
