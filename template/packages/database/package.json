{
  "name": "@repo/database",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "prisma generate && tsc -p tsconfig.build.json --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "lint": "eslint . --max-warnings 0",
    "pretypecheck": "pnpm run db:generate",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm run db:generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20",
    "eslint": "^9.32.0",
    "prisma": "^6.10.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "schema": "prisma/schema"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "default": "./dist/keys.js"
    },
    "./prisma": {
      "types": "./src/prisma.ts",
      "default": "./dist/prisma.js"
    }
  }
}
